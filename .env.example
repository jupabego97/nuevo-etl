# PostgreSQL — Opción A: BD dedicada nueva (despliegue elegido)
# Usar el DATABASE_URL del Postgres NUEVO en Railway, no el de cron-job.
#
# IMPORTANTE: cada variable en su propia línea. NO pegues varias en un solo valor.
# Mal:  DB_SCHEMA=alegra_etlCOMPANY_ID=1
# Bien:
DATABASE_URL=postgresql+psycopg://user:password@host:5432/railway
DB_SCHEMA=alegra_etl
COMPANY_ID=1

# Alegra API (usar uno de los dos métodos)
ALEGRA_EMAIL=your-email@example.com
ALEGRA_TOKEN=your-token
# ALEGRA_API_KEY=base64-encoded-key
ALEGRA_BASE_URL=https://api.alegra.com/api/v1

# Sincronización
SYNC_OVERLAP_DAYS=3
SYNC_PAGE_SIZE=30
SYNC_REQUEST_TIMEOUT_SECONDS=30

# Webhooks
WEBHOOK_SECRET=change-me-to-a-long-random-secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Logging y alertas
LOG_LEVEL=INFO
LOG_JSON=true
# ALERT_WEBHOOK_URL=https://hooks.example.com/alerts

# Feature flags (recursos opcionales por plan/país)
ENABLE_ACCOUNTING=true
ENABLE_BANKS=true
ENABLE_GLOBAL_INVOICES=false
ENABLE_TRANSPORTATION_RECEIPTS=false
